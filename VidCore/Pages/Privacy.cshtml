@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="privacy-container">
    <h1>@ViewData["Title"]</h1>

    <p><strong>Last Updated:</strong> June 2026</p>

    <h2>Information We Collect</h2>
    <p>
        VidCore may collect the following information:
    </p>
    <ul>
        <li>Username</li>
        <li>Email address</li>
        <li>Uploaded videos</li>
        <li>Comments</li>
        <li>Profile images</li>
        <li>Basic technical information required for site operation</li>
    </ul>

    <h2>How We Use Information</h2>
    <p>
        The collected information is used for:
    </p>
    <ul>
        <li>Operating user accounts</li>
        <li>Publishing user content</li>
        <li>Improving platform functionality</li>
        <li>Protecting the platform from abuse and malicious activity</li>
    </ul>

    <h2>Data Sharing</h2>
    <p>
        VidCore does not sell personal information to third parties.
    </p>

    <p>
        Information may only be disclosed when required by law or when necessary
        to protect the platform, its users, or its infrastructure.
    </p>

    <h2>Data Storage</h2>
    <p>
        User data may remain stored until the account or content is removed by
        the user or platform administration.
    </p>

    <h2>Security</h2>
    <p>
        We take reasonable measures to protect user information. However, no
        Internet service can guarantee absolute security.
    </p>

    <h2>User Responsibility</h2>
    <p>
        Users are solely responsible for the content they publish on VidCore.
    </p>

    <h2>Contact</h2>
    <p>
        If you have questions regarding privacy or data handling, please contact
        the VidCore administration.
    </p>
</div>