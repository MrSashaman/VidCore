@page
@model MusicPageModel
@{
    ViewData["Title"] = "Music";
}

<h1>Музыка</h1>

<div class="music-grid">
    @if (Model.Musics != null && Model.Musics.Any())
    {
        @foreach(var music in Model.Musics)
        {
            <div class="music-card">
                <audio class="music-player" controls>
                    <source src="@music.AudioPath">
                </audio>

                <div class="music-info">
                    <div class="music-title">@music.Title</div>
                    <div class="music-artist">@music.Artist</div>

                    <div class="music-stats">
                        <span>👍 <span class="likes-@music.Id">@music.Likes</span></span>
                        <form method="post" style="margin: 0; padding: 0; display: inline;">
                            <button type="submit" asp-page-handler="Like" asp-route-id="@music.Id" class="music-like-btn" title="Лайк">
                                👍
                            </button>
                            <button type="submit" asp-page-handler="Delete" asp-route-id="@music.Id" class="music-delete-btn" title="Удалить">
                                🗑️
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <p>Нет музыки</p>
    }
</div>
